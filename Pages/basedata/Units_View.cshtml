                                <input type="tel" class="control-input text-center" id="SharePercent" name="SharePercent" value="@Model.RowData["SharePercent"]">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'نشان دهنده تعداد افرادی است که در واحد اقامت دائم دارند. با ثبت تعداد ساکنین هرواحد میتوانید گزارش بگیرید که در مجتمع چند نفر ساکن دارید')">تعداد ساکنین</label>
                                <input type="tel" class="control-input text-center" name="NqSaken" value="@Model.RowData["NqSaken"]">
