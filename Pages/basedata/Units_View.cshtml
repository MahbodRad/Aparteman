@model Aparteman.Pages.basedata.UnitsModel
@using System.Data;
@using Aparteman.Services;
@{
}
@switch (@ViewData["Switch"])
{
    case "FormSabtUnit":
        <section class="container p-1">
            <div class="secondArea">
                @if (ViewData["ID"].ToString() == "0")
                {
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                    data-ajax-confirm="واحد جدید ذخیره گردد؟"
                    data-ajax-Btn="UpdateUnitBtn"
                    data-ajax-begin="SpinnerShowForm('چند لحظه صبر کنید');"
                    data-ajax-url="?handler=UpdateUnit"
                    data-ajax-complete="JsonResult">
                        <input type="hidden" name="ID" value="0" />

                        <div class="Area_Top bg-secondary text-white op-0-8">
                            <span class="font-18">اطلاعات اصلی</span>
                        </div>
                        <div class="mb-3">
                            <span class="control-label cursor-pointer" onclick="ShowFastHelp(this,'نامی که هر ساختمان با آن در سیستم شناخته می‌شود.این نام در گزارش‌ها و بخش‌های مدیریتی نمایش داده خواهد شد')">نام ساختمان</span>
                            <select class="control-input" name="BuildingId" onchange="FindListFloorAjax('FloorId',this, 'Not')">
                                @if (Model.ListBuilding.Rows.Count > 1)
                                {
                                    <option value="0">ابتدا ساختمان را انتخاب کنید</option>
                                }
                                @foreach (DataRow item in Model.ListBuilding.Rows)
                                {
                                    <option value="@item["BuildingId"]">@item["BuildingName"]</option>
                                }
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'طبقه ای که این واحد در آن قرار گرفته است')">طبقه</label>
                                <select class="control-input" id="FloorId" name="FloorId">
                                    @if (Model.ListBuilding.Rows.Count > 1)
                                    {
                                        <option value="0">ابتدا ساختمان را انتخاب کنید</option>
                                    }
                                    else{
                                        @foreach (DataRow item in Model.ListFloor.Rows)
                                        {
                                            <option value="@item["FloorId"]">@item["FloorTitle"]</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <div class="">
                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شماره ای که به هر واحد داده میشود. این شماره می تواند یکتا باشد و یا اینکه برای هر طبقه از یک شروع شود. میتوانید شماره را بصورت کدینگ تعریف کنید مثلا واحد 101 اشاره به واحد یک در طبقه اول دارد ')">شماره واحد</label>
                                    <input type="tel" class="control-input text-center" id="UnitNumber" name="UnitNumber">
                                </div>
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <div class="">
                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'مساحت واحد را بنویسید. از این مساحت در تسهیم هزینه هایی که وابسته به مساحت واحدها میباشد استفاده میشود')">متراژ</label>
                                    <input type="tel" class="control-input text-center" id="Area" name="Area">
                                </div>
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <div class="">
                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه اختیاری است. برای مواردی استفاده میشود که میخواهید تسهیم هزینه ها، صرف نظر از متراژی یا نفراتی یا واحدی، در ضریبی ضرب شود. مثلا در مجمع تصمیم گرفته میشود که بعضی از واحدها در شارژ تخفیف داشته باشند و یا بعضی دیگر شارژ بیشتری پرداخت کنند به عنوان مقال اگر این مفدار برای فردی 1.2 بنویسید، هر مبلغی که برای شارژ او حساب شود ضربدر عدد 1.2 میشود یعنی 20 درصد به هزینه شارژ او اضافه میشود تا پرداخت کند')">سهم شارژ</label>
                                    <input type="tel" class="control-input text-center" id="SharePercent" name="SharePercent" value="1">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 col-md-3 mb-3">
                                <div class="">
                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'نشان دهنده تعداد افرادی است که در واحد اقامت دائم دارند. با ثبت تعداد ساکنین هرواحد میتوانید گزارش بگیرید که در مجتمع چند نفر ساکن دارید')">تعداد ساکنین</label>
                                    <input type="tel" class="control-input text-center" name="NqSaken" value="1">
                                </div>
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <div class="">
                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'الزاما همه تعداد ساکنین یک واحد مشمول محاسبه شارژ برای هزینه های «تعداد نفرات» نمی شوند. به عنوان مثال ممکن است در مجمع تصمیم بگیرید که کودکان زیر 5 سال در محاسبات شارژ در نظر پرفته نشوند')">تعداد افراد مشمول شارژ</label>
                                    <input type="tel" class="control-input text-center" name="NqCharge" value="1">
                                </div>
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'ضریب آسانسور، برای هزینه های مرتبط با آسانسور در نظر گرفته شده است. هدف این استکه واحدها با توجه به طبقه، استفاده بیشتر یا کمتر از آسانسور دارند. برای طبقات بالاتر ضریب بیشتر و برای طبقات پانیتر ضریب کمتری بنویسید. مقدار ضریب بنا بر تصویب مجمع عمومی میباشد. پیش فرض این مقدار برای همه یکسان و یک می باشد')">ضریب آسانسور</label>
                                <input type="tel" class="control-input text-center" id="ZaribAsan" name="ZaribAsan" value="1">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'در هزینه هایی که پرداخت آنها به عهده مالک واحد میباشد، در صورتی مالک بدهکار میشود که این گزینه فعال باشد. در غیر اینصورت تسهیم هزینه مالک برای این واحد انجام نمی شود')">آیا شارژ مالک فعال است؟</label>
                                <img class="w-fix-75 cursor-pointer" src="/images/Btn_Yes.png" onclick="ToggelYesNo(this,'IsActiveMalek');" alt="Aparteman_YesNo" />
                                <input id="IsActiveMalek" hidden name="IsActiveMalek" value="1" />
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'در هزینه هایی که پرداخت آنها به عهده ساکن واحد میباشد، در صورتی ساکن بدهکار میشود که این گزینه فعال باشد. در غیر اینصورت تسهیم هزینه ساکن برای این واحد انجام نمی شود')">آیا شارژ ساکن فعال است؟</label>
                                <img class="w-fix-75 cursor-pointer" src="/images/Btn_Yes.png" onclick="ToggelYesNo(this,'IsActiveMalek');" alt="Aparteman_YesNo" />
                                <input id="IsActiveSaken" hidden name="IsActiveSaken" value="1" />
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <span class="control-label cursor-pointer" onclick="ShowFastHelp(this,'وضعیت فعلی واحد از لحاظ سکونت را انتخاب کنید. این مورد در گزارشات دقیق از وضعیت واحدها بسیار کاربردی است')">وضعیت</span>
                                <select class="control-input" id="RoleId" name="SitCode">
                                    <option value="1">خالی</option>
                                    <option value="2">مالک ساکن</option>
                                    <option value="3">مستاجر ساکن</option>
                                    <option value="4">در حال تعمیر</option>
                                    <option value="5">برای اجاره</option>
                                    <option value="6">برای فروش</option>
                                    <option value="7">رزرو شده</option>
                                    <option value="8">در اختیار کارکنان</option>
                                    <option value="9">غیرقابل استفاده</option>
                                </select>
                            </div>
                        </div>

                        <div class="Area_Top bg-secondary text-white op-0-8">
                            <span class="font-18">سایر اطلاعات</span>
                        </div>



