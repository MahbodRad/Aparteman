                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">دارای شومینه</label>
                                <img class="w-fix-75 cursor-pointer" src="/images/Btn_No.png" onclick="ToggelYesNo(this,'Shomine');" alt="Aparteman_YesNo" />
                                <input id="Shomine" hidden name="Shomine" value="0" />
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">تعداد خواب</label>
                                <input type="tel" class="control-input text-center" id="NqBed" name="NqBed" value="">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">شماره کنتور آب</label>
                                <input type="tel" class="control-input text-center" id="NumberWater" name="NumberWater" value="">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">شماره کنتور برق</label>
                                <input type="tel" class="control-input text-center" id="NumberBarg" name="NumberBarg" value="">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">شماره کنتور گاز</label>
                                <input type="tel" class="control-input text-center" id="NumBerGaz" name="NumBerGaz" value="">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">شماره پارکینگ</label>
                                <input type="tel" class="control-input text-center" id="NumberPark" name="NumberPark" value="">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">شماره انباری</label>
                                <input type="tel" class="control-input text-center" id="NumberStor" name="NumberStor" value="">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این گزینه فیلد اطلاعاتی است. و در محاسبات استفاده نمی شود')">مساحت انباری</label>
                                <input type="tel" class="control-input text-center" id="AreaStore" name="AreaStore" value="">
                            </div>
                        </div>

                        <div>
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'توضیحاتی در مورد این واحد. این توضیحات توسط مدیریت دیده می شود و توسط ساکن یا مالک دیده نمی شود')">شرح</label>
                            <input type="text" class="control-input text-center" id="Sharh" name="Sharh" maxlength="255" value="">
                        </div>
                        <hr />
                        <div class="text-end px-3">
                            <button type="submit" id="UpdateUnitBtn" class="btn_Icon Icon_Blue2 icofont-2x icofont-checked" title="ثبت شود"><span>ثبت شود</span></button>
                        </div>

                    </form>
                }
                else
                {
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                    data-ajax-confirm="اطلاعات واحد اصلاح گردد؟"
                    data-ajax-Btn="UpdateUnitBtn"
                    data-ajax-begin="SpinnerShowForm('چند لحظه صبر کنید');"
                    data-ajax-url="?handler=UpdateUnit"
                          data-ajax-complete="JsonClose_A">
                        <input type="hidden" name="ID" value="@ViewData["ID"]" />
                        <div class="Area_Top bg-secondary text-white op-0-8">
                            <span class="font-18">اطلاعات اصلی</span>
                        </div>

                        <div class="mb-3">
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'نامی که هر ساختمان با آن در سیستم شناخته می‌شود.این نام در گزارش‌ها و بخش‌های مدیریتی نمایش داده خواهد شد')">نام ساختمان</label>
                            <div class="Area_Pill bg-white">
                                <span>@Model.RowData["BuildingName"]</span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'طبقه ای که این واحد در آن قرار گرفته است')">طبقه</label>
                                <select class="control-input" id="FloorId" name="FloorId">
                                    @foreach (DataRow item in Model.ListFloor.Rows)
                                    {
                                        <option value="@item["FloorId"]">@item["FloorTitle"]</option>
                                    }
                                </select>
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شماره ای که به هر واحد داده میشود. این شماره می تواند یکتا باشد و یا اینکه برای هر طبقه از یک شروع شود. میتوانید شماره را بصورت کدینگ تعریف کنید مثلا واحد 101 اشاره به واحد یک در طبقه اول دارد ')">شماره واحد</label>
                                <input type="tel" class="control-input text-center" id="UnitNumber" name="UnitNumber" value="@Model.RowData["UnitNumber"]">
                            </div>
                            <div class="col-6 col-md-3 mb-3">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'مساحت واحد را بنویسید. از این مساحت در تسهیم هزینه هایی که وابسته به مساحت واحدها میباشد استفاده میشود')">متراژ</label>
                                <input type="tel" class="control-input text-center" id="Area" name="Area" value="@Model.RowData["Area"]">
