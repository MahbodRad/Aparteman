                    </div>

                    <hr />
                    <div class="d-flex justify-content-between px-3">
                        <div class="flex-fill text-Panevis">
                            <span>@Model.RowData["Editor"]</span><span class="w-fix-150 ltr mx-3">@Model.RowData["TimeEdit"]</span>
                        </div>
                        <button type="submit" id="UpdateKarbarBtn" class="btn_Icon Icon_Blue2 icofont-2x icofont-checked" title="ثبت شود"></button>
                    </div>

                </form>
                <div hidden>
                    <form method="post" data-ajax="true" data-ajax-method="post"
                            data-ajax-confirm="پسورد کاربر ذخیره گردد؟"
                            data-ajax-Btn="UpdatePassBtn"
                            data-ajax-begin="SpinnerShowForm('چند لحظه صبر کنید');"
                            data-ajax-url="?handler=UpdatePass"
                            data-ajax-complete="JsonResult">
                        <input type="hidden" name="PersonId" value="@Model.RowData["PersonId"]" />
                        <input type="submit" hidden id="UpdatePassBtn" name="PASS" />
                    </form>
                </div>
            </div>

            <div id="ResUpdateKarbar"></div>
        </section>


        break;



}
