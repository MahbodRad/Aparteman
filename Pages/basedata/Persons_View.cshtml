@model Aparteman.Pages.basedata.PersonsModel
@using System.Data;
@using Aparteman.Services;
@{
    var ZF = ""; var RJ = 0;
}
@switch (@ViewData["Switch"])
{
    case "ListPerson":

        <div class="d-flex flex-wrap justify-content-between border-top border-secondary">
            <div class="Area_Count w-fix-200">
                <span>تعداد : </span><span>@Model.ListPersons.Rows.Count </span>
            </div>
        </div>
        <div class="flex-fill text-end">
            <div class="Area_Print w-max-350">
                <form asp-antiforgery="true" method="get" data-ajax-method="get" data-ajax="true"
                      data-ajax-begin="SpinnerShowForm('در حال آماده سازی فایل گزارش');"
                      data-ajax-url="?handler=Chap_@ViewData["Switch"]"
                      data-ajax-complete="ControlChap('Chap_@ViewData["Switch"]Btn');">
                    <input type="hidden" name="ComText" value="@ViewData["ComText"]" />
                    <input type="submit" hidden id="Chap_@ViewData["Switch"]Btn" name="Chap" value="" />
                    <div class="d-flex p-2 pb-0 justify-content-end">
                        <input class="control-input w-100" name="OnvanChap" placeholder="عنوانی برای چاپ بنویسید" value="" />
                        <button type="button" title="چاپ" class="btn_Icon Icon_Gray icofont-2x icofont-print" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'CHAP');"></button>
                        <button type="button" title="پی دی اف" class="btn_Icon Icon_Gray icofont-2x icofont-file-pdf" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'PDF');"></button>
                        <button type="button" title="اکسل" class="btn_Icon Icon_Gray icofont-2x icofont-file-excel" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'XLS');"></button>
                    </div>
                </form>
            </div>
        </div>


        <div class="header_Table">
            <button type="button" class="btn_Icon footer_Right Icon_Red icofont-00x icofont-curved-double-right" title="اسکرول به راست" onclick="ScrollRight('@ViewData["Switch"]_FT');"></button>
            <button type="button" class="btn_Icon footer_Left Icon_Red icofont-00x icofont-curved-double-left" title="اسکرول به چپ" onclick="ScrollLeft('@ViewData["Switch"]_FT');"></button>
            <div id="@ViewData["Switch"]_FT" class="overflow-hidden" onscroll="ScrollSlave(this, '@ViewData["Switch"]_MS');">
                <table class="table grid-table">
                    <thead>
                        <tr>
                            <th><span>#</span></th>
                            <th><span class="w-fix-75"><i class="icofont-people"></i></span></th>
                            <th><span class="w-fix-200">نام</span></th>
                            <th><span class="w-fix-150">همراه</span></th>
                            <th><span class="w-fix-150">کد ملی</span></th>
                            <th><span class="w-fix-50">ویرایش</span></th>
                            <th><span class="w-fix-50">واحد</span></th>
                            <th><span class="w-fix-50">مرتبط</span></th>
                            <th><span class="w-fix-50">اسناد</span></th>
                            <th><span class="w-fix-100">نقش</span></th>
                            <th><span class="w-fix-100">واحد</span></th>
                            <th><span class="w-fix-100">طبقه</span></th>
                            <th><span class="w-fix-200">ساختمان</span></th>
                            <th><span class="w-fix-90">فعال است؟</span></th>
                            <th><span class="w-fix-250">ایمیل</span></th>
                            <th><span class="w-fix-50">حذف</span></th>
                            <th><span class="w-fix-180"><span>ویرایشگر</span> / <span>زمان</span></span></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
        <div class="overflow-auto" id="@ViewData["Switch"]_MS" onscroll="ScrollSlave(this, '@ViewData["Switch"]_FT');">
            <table class="table grid-table">
                <thead class="header_Tablehiden">
                    <tr>
                        <th><span>#</span></th>
                        <th><span class="w-fix-75"><i class="icofont-people"></i></span></th>
                        <th><span class="w-fix-200">نام</span></th>
                        <th><span class="w-fix-150">همراه</span></th>
                        <th><span class="w-fix-150">کد ملی</span></th>
                        <th><span class="w-fix-50">ویرایش</span></th>
                        <th><span class="w-fix-50">واحد</span></th>
                        <th><span class="w-fix-50">مرتبط</span></th>
                        <th><span class="w-fix-50">اسناد</span></th>
                        <th><span class="w-fix-100">نقش</span></th>
                        <th><span class="w-fix-100">واحد</span></th>
                        <th><span class="w-fix-100">طبقه</span></th>
                        <th><span class="w-fix-200">ساختمان</span></th>
                        <th><span class="w-fix-90">فعال است؟</span></th>
                        <th><span class="w-fix-250">ایمیل</span></th>
                        <th><span class="w-fix-50">حذف</span></th>
                        <th><span class="w-fix-180"><span>ویرایشگر</span> / <span>زمان</span></span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow item in Model.ListPersons.Rows)
                    {
                        { RJ++; }
                        <tr onclick="RowSelect(this);" id="Per_@item["PersonId"]">
                            <td class="text-danger">@RJ</td>
                            <td><img src="/Uploads/Persons/@item["Pic"]" class="Area_Pill w-100" /> </td>
                            <td><span class="w-fixC-200 text-start"><span>@item["FullName"]</span><span class="text_line23">@item["PersonId"]</span></span></td>
                            <td><span class="w-fixC-150 ltr">@item["Mobile"]</span></td>
                            <td><span class="w-fixC-150 ltr">@item["NationalCode"]</span></td>
                            <td>
                                <button type="button" class="btn_Icon Icon_Mor icofont-00x icofont-edit" title="ویرایش" onclick="ClickBtnSimpl('FormSabtPersonBtn', '@item["PersonId"]');"></button>
                            </td>
                            <td><span class="w-fixC-50"><button type="button" class="btn_Icon Icon_Blue icofont-00x icofont-home" title="واحد" onclick="ClickBtnSimpl('FormUnitBtn', '@item["PersonId"]','FormUnitPerson', '@item["Fullname"]' );"></button></span></td>
                            <td><span class="w-fixC-50"><button type="button" class="btn_Icon Icon_Blue icofont-00x icofont-people" title="افراد مرتبط" onclick="ClickBtnSimpl('FormRelationBtn', '@item["PersonId"]','FormRelationPerson', '@item["Fullname"]');"></button></span></td>
                            <td><span class="w-fixC-50"><button type="button" class="btn_Icon Icon_Blue icofont-00x icofont-file-alt" title="اسناد" onclick="ClickBtnSimpl('FormAsnadBtn', '@item["PersonId"]','FormAsnadPerson', '@item["Fullname"]');"></button></span></td>
                            <td><span class="w-fixC-100">@item["RoleTitle"]</span></td>
                            <td><span class="w-fixC-100 ltr">@item["UnitNumber"]</span></td>
                            <td><span class="w-fixC-100 text-start"><span>@item["FloorTitle"]</span><span class="text_line23">@item["FloorNumber"]</span></span></td>
                            <td><span class="w-fixC-200 text-start"><span>@item["BuildingName"]</span><span class="text_line23">@item["BuildingCode"]</span></span></td>
                            <td>
                                <span class="w-fixC-90">
                                    <img class="w-fix-75" src="@item["IsActiveIcon"]" alt="Aparteman_YesNo" />
                                </span>
                            </td>
                            <td><span class="w-fixC-250">@item["Email"]</span></td>

                            <td>
                                <button type="button" class="btn_Icon Icon_Red icofont-00x icofont-delete" title="حذف" onclick="ClickBtnSimpl('DeletePersonBtn', '@item["PersonId"]');"></button>
                            </td>
                            <td><span class="w-fixC-180 text-start"><span>@item["EditorName"]</span><span class="text_line23 ltr">@item["TimeEdit"]</span></span></td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

        <div hidden>
            <form method="post" data-ajax="true" data-ajax-method="post"
            data-ajax-confirm="آیا این شخص حذف گردد؟"
            data-ajax-Btn="DeletePersonBtn"
            data-ajax-begin="SpinnerShowForm('چند لحظه صبر کنید');"
            data-ajax-url="?handler=DeletePerson"
                  data-ajax-complete="JsonResultOK"
            data-ajax-success="AreaHide('Per_'+EleValue('DeletePersonBtn'))">
                <input type="submit" hidden id="DeletePersonBtn" name="ID" />
            </form>

        </div>
        break;


    case "FormSabtPerson":
        <section class="container p-1">
            <div class="secondArea p-2">
                @if (@ViewData["ID"].ToString() == "0")
                {
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                    data-ajax-confirm="آیا شخص جدید به سیستم اضافه گردد؟"
                    data-ajax-Btn="UpdatePersonBtn"
                    data-ajax-begin="SpinnerShowForm('چند لحظه صبر کنید');"
                    data-ajax-url="?handler=UpdatePerson"
                    data-ajax-complete="JsonResult">
                        <input type="hidden" name="ID" value="@ViewData["ID"]" />

                        <div class="Area_Top bg-secondary text-white op-0-8">
                            <span class="font-18">اطلاعات اصلی</span>
                        </div>

                        <div class="row py-1">
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'نام و نام خانوادگی شخص را بنویسید. برای اشخاص حقوقی نام شرکت را بنویسید. این فیلد اجباری است، ')">نام</label>
                                <input type="text" id="jsFullName" name="FullName" class="control-input text-center" maxlength="75" />
                            </div>
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شماره همراه اشخاص اجباری است. از این شماره برای تماس با اشخاص استفاده میشود و بایستی معتبر باشد')">موبایل</label>
                                <input type="tel" onkeyup="onlyNumber(this)" id="jsMobile" name="Mobile" class="control-input text-center ltr" maxlength="20" />
                            </div>
                        </div>
                        <div class="row py-1">
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'در صورت نیاز کد ملی اشخاص ثبت شود. از کد ملی میتوان در موارد حقوقی استفاده کرد')">کد ملی</label>
                                <input type="tel" onkeyup="onlyNumber(this)" name="NationalCode" class="control-input ltr text-center" maxlength="11">
                            </div>
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'ایمیل اشخاص ثبت شود. این فیلد ضروری نیست. اما برای ارسال گزارشات و نامه ها به ایمیل استفاده میشود.')">ایمیل</label>
                                <input type="email" name="Email" class="control-input ltr" maxlength="100" />
                            </div>
                        </div>

                        <div class="row py-1">
                            <div class="col-6">
                                <span class="control-label" onclick="ShowFastHelp(this,'معمولا افراد بعد از مدتی از مجتمع میروند و دیگر نیازی نیست که برای امور مالی و موارد مشابه مجتمع انتخاب شوند. در این صورت با غیر فعال کردن وضعیت آنها، اسم این افراد دیگر دیده نمی شود. اما همچنان سابقه قعالیتشان در گزارشات مشاهده میشود')">وضعیت در سیستم فعال است؟</span>
                                <img class="w-fix-75 cursor-pointer" src="/images/Btn_Yes.png" onclick="ToggelYesNo(this,'IsActive');" alt="Aparteman_YesNo" />
                                <input type="hidden" id="IsActive" name="IsActive" value="1" />
                            </div>
                            <div class="col-6">
                                <span class="control-label" onclick="ShowFastHelp(this,'درصورتی میخواهید این فرد بتواند به عنوان کاربر سیستم وارد سایت شود. این گزینه را «بلی» کنید. برای او یک کاربری ایجاد می شود که در قسمت کاربران می توانید سطح دسترسی او را مدیریت کنید')">آیا کاربر سایت است؟</span>
                                <img class="w-fix-75 cursor-pointer" src="/images/Btn_No.png" onclick="ToggelYesNo(this,'IsUser');" alt="Aparteman_YesNo" />
                                <input type="hidden" id="IsUser" name="IsUser" value="0" />
                            </div>
                        </div>

                        <div class="Area_Top bg-secondary text-white op-0-8 mt-2">
                            <span class="font-18">سایر اطلاعات</span>
                        </div>
                        <div class="row py-1">
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'برای احراز هویت، ارسال اعلان‌های رسمی یا مالی')">تاریخ تولد</label>
                                <div class="control-Date">
                                    <input placeholder="1400/01/01" id="BirthDate" name="BirthDate" maxlength="10" readonly class="usage control-input-plaintext" value="" />
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'فیلد اطلاعاتی برای تماس های ضروری')">تلفن ثابت</label>
                                <input type="text" onkeyup="onlyNumber(this)" name="Phone" class="control-input text-center ltr" value="" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شرحی مناسب یا یادداشتی در مورد این شخص بنویسید. شرح صرفا اطلاعاتی است و فقط مدیریت مجتمع میتواند آن را ببیند و به خود شخص نمایش داده نمی شود. مثلا: معلولیت، حیوان خانگی، نیازهای ویژه')">بادداشت</label>
                            <textarea name="Sharh" class="control-input-Area" rows="2" maxlength="150"></textarea>
                        </div>
                        <hr />
                        <div class="text-end px-3">
                            <button type="submit" id="UpdatePersonBtn" class="btn_Icon Icon_Blue2 icofont-2x icofont-checked" title="ثبت شود"><span>ثبت شود</span></button>
                        </div>
                    </form>
                }
                else
                {
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                    data-ajax-confirm="آیا اطلاعات این شخص اصلاح گردد؟"
                    data-ajax-Btn="UpdatePersonBtn"
                    data-ajax-begin="SpinnerShowForm('چند لحظه صبر کنید');"
                    data-ajax-url="?handler=UpdatePerson"
                    data-ajax-complete="JsonClose_A">
                        <input type="hidden" name="ID" value="@ViewData["ID"]" />

                        <div class="Area_Top bg-secondary text-white op-0-8">
                            <span class="font-18">اطلاعات اصلی</span>
                        </div>
                        <div class="row py-1">
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'نام و نام خانوادگی شخص را بنویسید. برای اشخاص حقوقی نام شرکت را بنویسید. این فیلد اجباری است، ')">نام</label>
                                <input type="text" name="FullName" class="control-input text-center" maxlength="75" value="@Model.RowData["FullName"]" />
                            </div>
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شماره همراه اشخاص اجباری است. از این شماره برای تماس با اشخاص استفاده میشود و بایستی معتبر باشد')">موبایل</label>
                                <input type="tel" onkeyup="onlyNumber(this)" name="Mobile" class="control-input text-center ltr" maxlength="20" value="@Model.RowData["Mobile"]" />
                            </div>
                        </div>
                        <div class="row py-1">
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'در صورت نیاز کد ملی اشخاص ثبت شود. از کد ملی میتوان در موارد حقوقی استفاده کرد')">کد ملی</label>
                                <input type="tel" onkeyup="onlyNumber(this)" name="NationalCode" class="control-input ltr text-center" maxlength="11" value="@Model.RowData["NationalCode"]">
                            </div>
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'ایمیل اشخاص ثبت شود. این فیلد ضروری نیست. اما برای ارسال گزارشات و نامه ها به ایمیل استفاده میشود.')">ایمیل</label>
                                <input type="email" name="Email" class="control-input ltr" maxlength="100" value="@Model.RowData["Email"]" />
                            </div>
                        </div>

                        <div class="row py-1">
                            <div class="col-6">
                                <span class="control-label" onclick="ShowFastHelp(this,'معمولا افراد بعد از مدتی از مجتمع میروند و دیگر نیازی نیست که برای امور مالی و موارد مشابه مجتمع انتخاب شوند. در این صورت با غیر فعال کردن وضعیت آنها، اسم این افراد دیگر دیده نمی شود. اما همچنان سابقه قعالیتشان در گزارشات مشاهده میشود')">وضعیت در سیستم فعال است؟</span>
                                <img class="w-fix-75 cursor-pointer" src="@Model.RowData["IsActiveIcon"]" onclick="ToggelYesNo(this,'IsActive');" alt="Aparteman_YesNo" />
                                <input type="hidden" id="IsActive" name="IsActive" value="@Model.RowData["IsActive"].ToYesNo()" />
                            </div>
                            <div class="col-6">
                                <span class="control-label" onclick="ShowFastHelp(this,'درصورتی میخواهید این فرد بتواند به عنوان کاربر سیستم وارد سایت شود. این گزینه را «بلی» کنید. برای او یک کاربری ایجاد می شود که در قسمت کاربران می توانید سطح دسترسی او را مدیریت کنید')">آیا کاربر سایت است؟</span>
                                <img class="w-fix-75 cursor-pointer" src="@Model.RowData["IsUserIcon"]" onclick="ToggelYesNo(this,'IsUser');" alt="Aparteman_YesNo" />
                                <input type="hidden" id="IsUser" name="IsUser" value="@Model.RowData["IsUser"].ToYesNo()" />
                            </div>
                        </div>

                        <div class="Area_Top bg-secondary text-white op-0-8 mt-2">
                            <span class="font-18">سایر اطلاعات</span>
                        </div>
                        <div class="row py-1">
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'برای احراز هویت، ارسال اعلان‌های رسمی یا مالی')">تاریخ تولد</label>
                                <div class="control-Date">
                                    <input placeholder="1400/01/01" id="BirthDate" name="BirthDate" maxlength="10" readonly class="usage control-input-plaintext" value="@Model.RowData["BirthDate"]" />
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'فیلد اطلاعاتی برای تماس های ضروری')">تلفن ثابت</label>
                                <input type="text" onkeyup="onlyNumber(this)" name="Phone" class="control-input text-center ltr" value="@Model.RowData["Phone"]" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شرحی مناسب یا یادداشتی در مورد این شخص بنویسید. شرح صرفا اطلاعاتی است و فقط مدیریت مجتمع میتواند آن را ببیند و به خود شخص نمایش داده نمی شود')">بادداشت</label>
                            <textarea name="Sharh" class="control-input-Area" rows="2" maxlength="150">@Model.RowData["Sharh"]</textarea>
                        </div>
                        <hr />
                        <div class="text-end px-3">
                            <button type="submit" id="UpdatePersonBtn" class="btn_Icon Icon_Blue2 icofont-2x icofont-checked" title="ثبت شود"><span>ثبت شود</span></button>
                        </div>
                    </form>
                }
            </div>
            <script>
                ControlPersianDate('BirthDate');
            </script>
        </section>

        break;

    case "FormUnit":
        <section class="container p-1">
            <div class="secondArea p-2">
                <form method="get" data-ajax="true" data-ajax-method="get"
                      data-ajax-begin="MsgFormSpinner('B','تخصیص واحد به شخص', 'چند لحظه صبر کنید');"
                      data-ajax-url="?handler=FormSabtUnit"
                      data-ajax-update="#MsgFormMATN_B">
                    <input type="hidden" name="PersonName" value="@ViewData["PersonName"]" />
                    <input type="hidden" name="PersonId" value="@ViewData["PersonId"]" />
                    <input type="submit" hidden id="FormSabtUnitBtn" name="ID" />
                    <div class="p-2 text-end">
                        <button type="button" class="BTN btn_Pill btn_Blue2 w-fix-225" onclick="ClickBtnSimpl('FormSabtUnitBtn','0');"><span>افزودن واحد جدید</span><i class="icofont-00x icofont-plus float-end"></i></button>
                    </div>
                </form>
                <div id="D_ResUnit">
                    @if(Model.ListUnit.Rows.Count == 0)
                    {
                        <div class="alert alert-danger">
                            <h5>هنوز واحدی را به «@ViewData["PersonName"]»  تخصیص نداده اید</h5>
                        </div>
                    }else
                    {
                        <div class="d-flex flex-wrap justify-content-between">
                            <div class="Area_Count w-fix-200">
                                <span>تعداد : </span><span>@Model.ListUnit.Rows.Count </span>
                            </div>
                        </div>

                        <div class="header_Table">
                            <button type="button" class="btn_Icon footer_Right Icon_Red icofont-00x icofont-curved-double-right" title="اسکرول به راست" onclick="ScrollRight('@ViewData["Switch"]_FT');"></button>
                            <button type="button" class="btn_Icon footer_Left Icon_Red icofont-00x icofont-curved-double-left" title="اسکرول به چپ" onclick="ScrollLeft('@ViewData["Switch"]_FT');"></button>
                            <div id="@ViewData["Switch"]_FT" class="overflow-hidden" onscroll="ScrollSlave(this, '@ViewData["Switch"]_MS');">
                                <table class="table grid-table">
                                    <thead>
                                        <tr>
                                            <th><span>#</span></th>
                                            <th><span class="w-fix-150">نقش</span></th>
