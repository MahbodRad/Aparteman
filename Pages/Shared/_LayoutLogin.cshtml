<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title>@ViewData["Title"]</title>

    <style>
        body {
            min-height: 100vh;
        }
    </style>
    <meta charset="utf-8" />
    <environment include="Development">
        <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.css" rel="stylesheet" />
        <link href="~/fonts/icofont/icofont.css" rel="stylesheet" />
    </environment>
    <environment exclude="Development">
        <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
        <link href="~/fonts/icofont/icofont.min.css" rel="stylesheet" />
    </environment>
    @* <script src="https://www.google.com/recaptcha/api.js" async defer></script> *@

    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/styles.css" rel="stylesheet" />


</head>
<body class="text-start back-ground-Login d-flex align-items-center justify-content-center">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-7 col-md-9">
                <div>
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <!-- راهنما -->
    <form hidden method="get" data-ajax-method="get" data-ajax="true"
          data-ajax-begin="SpinnerShow('HelpArea');"
          data-ajax-url="../ApiCenter?handler=HelpShow"
          data-ajax-update="#HelpArea">
        <input hidden type="submit" id="HelpBtn" name="ID" value="36" />

    </form>
    <!-- پنجره پیامها -->
    <div id="MsgAreaModal">
        <div class="alert alert-primary border border-1 border-danger w-max-500 w-min-330 mx-auto box-shadow">
            <div class="text-start">
                <h6 class="text-primary"><span class="text-danger m-2 icofont icofont-00x icofont-warning-alt"></span><span id="ShowMsg_TITR"> heading </span></h6>
                <hr />
                <div class="text-center" id="ShowMsg_MATN">
                    Msg body..
                </div>
                <hr />
                <div class="text-end px-2">
                    <button type="button" class="btn_Icon Icon_Brown icofont-00x icofont-thumbs-up" onclick="AreaHide('MsgAreaModal'); AreaClear('ShowMsg_MATN');"></button>
                </div>
            </div>
        </div>
    </div>




    <!-- پنجره انتظار -->
    <div id="ModalSpiner">
        <div class="w-fix-250 border border-info rounded rounded-3">
            <div class="py-2">
                <h6 class="text-warning" id="SpinnerMsg_TITR">Heading</h6>
            </div>
            <div class="modal-body text-center">
                <img src="../images/loading.gif" class="w-max-100" />
                <div class="timer" id="timerForm">0</div>
            </div>

            <div class="text-center">
                <button type="button" class="btn_IconPill Icon_Brown icofont-3x icofont-toggle-off mx-auto" onclick="SpinnerHideForm()"></button>
            </div>
        </div>
    </div>

    <!-- پنجره کانفرم -->
    <div id="ConfirmModal">
        <input type="hidden" id="ConfirmFormBtn" value="" />
        <div>
            <div class="alert alert-primary border border-1 border-danger w-min-300 w-max-500 box-shadow">
                <div class="text-start">
                    <span class="text-danger m-2"><span class="icofont icofont-00x icofont-notification"></span> توجه: </span>
                    <hr />
                    <h5 id="ConfirmMsg"></h5>
                    <hr />
                </div>
                <div class="d-flex justify-content-around" onkeyup="EnterKey(event, 'ConfirmModalClose');">
                    <button type="button" class="btn_Icon Icon_Blue icofont-2x icofont-checked" onclick="ClickBtn(EleValue('ConfirmFormBtn'));AreaHide('ConfirmModal');"><span style="font-family: DastNevis;">بلی</span></button>
                    <button type="button" class="btn_Icon Icon_Red icofont-2x icofont-close active" id="ConfirmModalClose" onclick="SetConfirm(); AreaHide('ConfirmModal');"><span style="font-family: DastNevis;">خیر</span></button>
                </div>
            </div>
        </div>
    </div>


    <environment include="Development">
        <script src="~/lib/jquery/dist/jquery.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.min.js"></script>
    </environment>

    <script src="~/js/site.js"></script>
    <script src="~/js/Ajax.js"></script>
</body>
</html>
