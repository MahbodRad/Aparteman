                            <button type="submit" id="UpdateTransferBtn" class="BTN btn_Pill btn_Blue2" title="اصلاح پرداخت مبلغ ثبت شود"><span>اصلاح پرداخت مبلغ ثبت شود</span><i class=" icofont-00x icofont-check"></i></button>
                        </div>

                    </form>
                    <script>
                        SetValueSimpl('Update_AccountBed','@Model.RowData["AccountBed"]','Update_AccountBes','@Model.RowData["AccountBes"]');
                        {
                            const DetailCodeBes = '@Model.RowData["DetailCodeBes"].ToString()';
                            if(DetailCodeBes != '4'){
                                AreaShow('tafziliBesArea');
                                AreaShow('tafziliBes_'+DetailCodeBes);
                            }
                            const DetailCodeBed = '@Model.RowData["DetailCodeBed"].ToString()';
                            if(DetailCodeBed != '4'){
                                AreaShow('tafziliBedArea');
                                AreaShow('tafziliBed_'+DetailCodeBed);
                            }
                        }
                    </script>

                }
            </div>
        </section>
        <script>
            ControlPersianDate('DateAction');
        </script>

        break;

    case "RepListTransfer":
        <div class="d-flex flex-wrap justify-content-between">
            <div class="Area_Count w-fix-200">
                <span>تعداد : </span><span>@Model.ListData.Rows.Count </span>
            </div>
            <div class="flex-fill text-end">
                <div class="Area_Print w-max-350">
                    <form asp-antiforgery="true" method="get" data-ajax-method="get" data-ajax="true"
                          data-ajax-begin="SpinnerShowForm('در حال آماده سازی فایل گزارش');"
                          data-ajax-url="?handler=Chap_@ViewData["Switch"]"
                          data-ajax-complete="ControlChap('Chap_@ViewData["Switch"]Btn');">
                        <input type="hidden" name="ComText" value="@ViewData["ComText"]" />
                        <input type="submit" hidden id="Chap_@ViewData["Switch"]Btn" name="Chap" value="" />
                        <div class="d-flex p-2 pb-0 justify-content-end">
                            <input class="control-input w-100" name="OnvanChap" placeholder="عنوانی برای چاپ بنویسید" value="" />
                            <button type="button" title="چاپ" class="btn_Icon Icon_Gray icofont-2x icofont-print" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'CHAP');"></button>
                            <button type="button" title="پی دی اف" class="btn_Icon Icon_Gray icofont-2x icofont-file-pdf" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'PDF');"></button>
                            <button type="button" title="اکسل" class="btn_Icon Icon_Gray icofont-2x icofont-file-excel" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'XLS');"></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="header_Table">
            <button type="button" class="btn_Icon footer_Right Icon_Red icofont-00x icofont-curved-double-right" title="اسکرول به راست" onclick="ScrollRight('@ViewData["Switch"]_FT');"></button>
            <button type="button" class="btn_Icon footer_Left Icon_Red icofont-00x icofont-curved-double-left" title="اسکرول به چپ" onclick="ScrollLeft('@ViewData["Switch"]_FT');"></button>
            <div id="@ViewData["Switch"]_FT" class="overflow-hidden" onscroll="ScrollSlave(this, '@ViewData["Switch"]_MS');">
                <table class="table grid-table">
                    <thead>
                        <tr>
                            <th><span>#</span></th>
                            <th><span class="w-fix-100">تاریخ</span></th>
                            <th><span class="w-fix-90">شماره سند</span></th>
                            <th><span class="w-fix-50">ویرایش</span></th>
                            <th><span class="w-fix-50">پیوست</span></th>
                            <th><span class="w-fix-180">مبلغ</span></th>
                            <th><span class="w-fix-250">از حساب</span></th>
                            <th><span class="w-fix-250">به حساب</span></th>
                            <th><span class="w-fix-350">شرح</span></th>
                            <th><span class="w-fix-150">وضعیت</span></th>
                            <th><span class="w-fix-200">زمان ثبت</span></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
        <div class="overflow-auto" id="@ViewData["Switch"]_MS" onscroll="ScrollSlave(this, '@ViewData["Switch"]_FT');">
            <table class="table grid-table">
                <thead class="header_Tablehiden">
                    <tr>
                        <th><span>#</span></th>
                        <th><span class="w-fix-100">تاریخ</span></th>
                        <th><span class="w-fix-90">شماره سند</span></th>
                        <th><span class="w-fix-50">ویرایش</span></th>
                        <th><span class="w-fix-50">پیوست</span></th>
                        <th><span class="w-fix-180">مبلغ</span></th>
                        <th><span class="w-fix-250">از حساب</span></th>
                        <th><span class="w-fix-250">به حساب</span></th>
                        <th><span class="w-fix-350">شرح</span></th>
                        <th><span class="w-fix-150">وضعیت</span></th>
                        <th><span class="w-fix-200">زمان ثبت</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow item in Model.ListData.Rows)
                    {
                        { RJ++; }
                        <tr onclick="RowSelect(this);">
                            <td class="text-danger">@RJ</td>
                            <td><span class="w-fixC-100">@item["EventDate"]</span></td>
                            <td><span class="w-fixC-90">@item["FinancialNum"]</span></td>
                            <td>
                                <button type="button" class="btn_Icon Icon_Mor icofont-2x icofont-edit" title="ویرایش" onclick="ClickBtnSimpl('FormSabtTransferBtn', '@item["FinancialEventId"]');"></button>
                            </td>
                            <td>
                                @if (@item["NameFile"].ToString() != "")
                                {
                                    <a class="btn_Icon Icon_Mor icofont-2x icofont-list" title="پیوست" target="_blank" href="/Uploads/VoucherAttach/@item["NameFile"]"></a>
                                }
                            </td>
                            <td><span class="w-fixC-180">@Html.Raw(@item["Amount"].ToMonySymbol())</span></td>
                            <td><span class="w-fixC-250">@item["AccountBes"]</span></td>
                            <td><span class="w-fixC-250">@item["AccountBed"]</span></td>
                            <td><span class="w-fixC-350">@item["Sharh"]</span></td>
                            <td><span class="w-fixC-150">@item["SitTitle"]</span></td>

                            <td><span class="w-fixC-200 text-start"><span>@item["EditorName"]</span><span class="text_line23">@item["TimeEdit"]</span></span></td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

        break;
}