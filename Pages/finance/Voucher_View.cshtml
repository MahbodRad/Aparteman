@model Aparteman.Pages.finance.VoucherModel
@using System.Data;
@using Aparteman.Services;
@{
    var RJ = 0;
}
@switch (@ViewData["Switch"])
{

    case "FormSabtVoucher":
        <section class="container p-1">
            <div class="secondArea">
                @if (@ViewData["ID"].ToString() == "0")
                {
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                          enctype="multipart/form-data"
                          data-ajax-confirm="آیا سربرگ سند حسابداری ثبت گردد؟"
                          data-ajax-Btn="FinancialEventsBtn"
                          data-ajax-begin="SpinnerShowForm('ایجاد سربرگ سند', 'چند لحظه صبر کنید');"
                          data-ajax-url="?handler=UpdateFinancialEvents"
                          data-ajax-complete="FinancialEventsComplete">
                        <input type="hidden" name="ID" value="@ViewData["ID"]" />

                        <div class="">
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'تاریخی که می خواهید سند در آن روز ایجاد شود را انتخاب کنید.')">تاریخ سند </label>
                            <div class="control-Date w-fix-150">
                                <input id="DateAction" name="DateAction" maxlength="10" readonly class="usage control-input-plaintext" value="@ViewData["Today"]" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شرح مناسبی در مورد این سند مالی بنویسید. شرح را بگونه ای بنویسید که محتوای سند را توضیح بدهد')">شرح</label>
                            <textarea class="form-control text-center" rows="2" maxlength="300" name="Sharh"></textarea>
                        </div>

                        <hr />
                        <div class="text-end px-3">
                            <button type="submit" id="FinancialEventsBtn" class="BTN btn_Pill btn_Blue2" title="سربرگ سند ایجاد شود"><span>سربرگ سند ایجاد شود</span><i class=" icofont-00x icofont-check"></i></button>
                        </div>

                    </form>
                }
                else{
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                          enctype="multipart/form-data"
                          data-ajax-confirm="آیا سربرگ سند حسابداری اصلاح گردد؟"
                          data-ajax-Btn="FinancialEventsBtn"
                          data-ajax-begin="SpinnerShowForm('اصلاح سربرگ سند', 'چند لحظه صبر کنید');"
                          data-ajax-url="?handler=UpdateFinancialEvents"
                          data-ajax-complete="JsonResult">
                        <input type="hidden" name="ID" value="@ViewData["ID"]" />

                        <div class="d-flex flex-wrap">
                            <div class="">
                                <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'تاریخی که می خواهید سند در آن روز ایجاد شود را انتخاب کنید.')">تاریخ سند </label>
                                <div class="control-Date w-fix-150">
                                    <input id="DateAction" name="DateAction" maxlength="10" readonly class="usage control-input-plaintext" value="@Model.RowData["EventDate"]" />
                                </div>
                            </div>
                            <div class="flex-fill">
                                <div class="d-flex justify-content-around">
                                    <div class="w-fix-200">
                                        <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'جمع کل مبالغی که از حسابهای این سند برداشت شده است.')">جمع کل بستانکار</label>
                                        <span class="control-text">@Html.Raw(@Model.RowData["Bes"].ToMonySymbol())</span>
                                    </div>
                                    <div class="w-fix-200">
                                        <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'جمع کل مبالغی که به حسابهای این سند واریز شده است.')">جمع کل بدهکار</label>
                                        <span class="control-text">@Html.Raw(@Model.RowData["Bed"].ToMonySymbol())</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شرح مناسبی در مورد این سند مالی بنویسید. شرح را بگونه ای بنویسید که محتوای سند را توضیح بدهد')">شرح</label>
                            <textarea class="form-control text-center" rows="2" maxlength="300" name="Sharh">@Model.RowData["Sharh"]</textarea>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between px-3">
                            <button type="button" class="BTN btn_Pill btn_Blue2" onclick="ClickBtnSimpl('FormSabtVoucherItemBtn','0');"><span>افزودن ردیف به سند</span><i class="icofont-00x icofont-plus"></i></button>
                            <button type="submit" id="FinancialEventsBtn" class="BTN btn_Pill btn_Blue2" title="اصلاح سربرگ شود"><span>اصلاح سربرگ سند شود</span><i class=" icofont-00x icofont-check"></i></button>
                        </div>
                    </form>
                    <form method="get" data-ajax="true" data-ajax-method="get"
                          data-ajax-begin="MsgFormSpinner('B','افزودن ردیف به سند حسابداری', 'چند لحظه صبر کنید');"
                          data-ajax-url="?handler=FormSabtVoucherItem"
                          data-ajax-update="#MsgFormMATN_B">
                        <input type="hidden" name="BedBes" value="@Model.RowData["BedBes"]" />
                        <input type="hidden" name="EventID" value="@ViewData["ID"]" />
                        <input type="submit" hidden id="FormSabtVoucherItemBtn" name="ItemID" value="0" />
                    </form>
                    <div>
                        @if(@Model.ListData.Rows.Count == 0){
                            <div class="container-fluid">
                                <div class="mt-3" id="RepListVouchers">
                                    <div class="alert alert-info w-max-400 mx-auto cursor-pointer" onclick="ClickBtnSimpl('FormSabtVoucherItemBtn','0');">
                                        <i class="icofont-plus" style="font-size:40px;"></i>
                                        <h6 class="mt-3">هنوز دیتابی برای این سند ثبت نکرده اید</h6>
                                        <p class="text-muted">برای ثبت دیتای سند کلیک کنید، </p>
                                    </div>
                                </div>
                            </div>
                        }
                        else{
                            <div class="d-flex flex-wrap justify-content-between">
                                <div class="Area_Count w-fix-200">
                                    <span>تعداد : </span><span>@Model.ListData.Rows.Count </span>
                                </div>
                            </div>

                            <div class="header_Table">
                                <button type="button" class="btn_Icon footer_Right Icon_Red icofont-00x icofont-curved-double-right" title="اسکرول به راست" onclick="ScrollRight('@ViewData["Switch"]_FT');"></button>
                                <button type="button" class="btn_Icon footer_Left Icon_Red icofont-00x icofont-curved-double-left" title="اسکرول به چپ" onclick="ScrollLeft('@ViewData["Switch"]_FT');"></button>
                                <div id="@ViewData["Switch"]_FT" class="overflow-hidden" onscroll="ScrollSlave(this, '@ViewData["Switch"]_MS');">
                                    <table class="table grid-table">
                                        <thead>
                                            <tr>
                                                <th><span>#</span></th>
                                                <th><span class="w-fix-200">حساب</span></th>
                                                <th><span class="w-fix-150">بستانکار</span></th>
                                                <th><span class="w-fix-150">بدهکار</span></th>
                                                <th><span class="w-fix-200">تفصیلی</span></th>
                                                <th><span class="w-fix-250">شرح</span></th>
                                            </tr>
                                        </thead>
                                    </table>
                                </div>
                            </div>
                            <div class="overflow-auto" id="@ViewData["Switch"]_MS" onscroll="ScrollSlave(this, '@ViewData["Switch"]_FT');">
                                <table class="table grid-table">
                                    <thead class="header_Tablehiden">
                                        <tr>
                                            <th><span>#</span></th>
                                            <th><span class="w-fix-200">حساب</span></th>
                                            <th><span class="w-fix-150">بستانکار</span></th>
                                            <th><span class="w-fix-150">بدهکار</span></th>
                                            <th><span class="w-fix-200">تفصیلی</span></th>
                                            <th><span class="w-fix-250">شرح</span></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (DataRow item in Model.ListData.Rows)
                                        {
                                            { RJ++; }
                                            <tr onclick="RowSelect(this);">
                                                <td class="text-danger">@RJ</td>
                                                <td><span class="w-fixC-200 text-start"><span>@item["AccountTitle"]</span><span class="text_line23">@item["AccountCode"]</span></span></td>
                                                <td><span class="w-fixC-150">@Html.Raw(@item["Bes"].ToMonySymbol())</span></td>
                                                <td><span class="w-fixC-150">@Html.Raw(@item["Bed"].ToMonySymbol())</span></td>
                                                <td><span class="w-fixC-200">@item["DetailFullName"]</span></td>
                                                <td><span class="w-fixC-250">@item["Babat"]</span></td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                        }

                    </div>
                }
            </div>
        </section>
        <script>
            ControlPersianDate('DateAction');
        </script>
        break;


    case "RepListVouchers":
        <div class="d-flex flex-wrap justify-content-between">
            <div class="Area_Count w-fix-200">
                <span>تعداد : </span><span>@Model.ListData.Rows.Count </span>
            </div>
            <div class="flex-fill text-end">
                <div class="Area_Print w-max-350">
                    <form asp-antiforgery="true" method="get" data-ajax-method="get" data-ajax="true"
                          data-ajax-begin="SpinnerShowForm('در حال آماده سازی فایل گزارش');"
                          data-ajax-url="?handler=Chap_@ViewData["Switch"]"
                          data-ajax-complete="ControlChap('Chap_@ViewData["Switch"]Btn');">
                        <input type="hidden" name="ComText" value="@ViewData["ComText"]" />
                        <input type="submit" hidden id="Chap_@ViewData["Switch"]Btn" name="Chap" value="" />
                        <div class="d-flex p-2 pb-0 justify-content-end">
                            <input class="control-input w-100" name="OnvanChap" placeholder="عنوانی برای چاپ بنویسید" value="" />
                            <button type="button" title="چاپ" class="btn_Icon Icon_Gray icofont-2x icofont-print" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'CHAP');"></button>
                            <button type="button" title="پی دی اف" class="btn_Icon Icon_Gray icofont-2x icofont-file-pdf" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'PDF');"></button>
                            <button type="button" title="اکسل" class="btn_Icon Icon_Gray icofont-2x icofont-file-excel" onclick="ClickBtnSimpl('Chap_@ViewData["Switch"]Btn', 'XLS');"></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="header_Table">
            <button type="button" class="btn_Icon footer_Right Icon_Red icofont-00x icofont-curved-double-right" title="اسکرول به راست" onclick="ScrollRight('@ViewData["Switch"]_FT');"></button>
            <button type="button" class="btn_Icon footer_Left Icon_Red icofont-00x icofont-curved-double-left" title="اسکرول به چپ" onclick="ScrollLeft('@ViewData["Switch"]_FT');"></button>
            <div id="@ViewData["Switch"]_FT" class="overflow-hidden" onscroll="ScrollSlave(this, '@ViewData["Switch"]_MS');">
                <table class="table grid-table">
                    <thead>
                        <tr>
                            <th><span>#</span></th>
                            <th><span class="w-fix-100">تاریخ</span></th>
                            <th><span class="w-fix-90">شماره سند</span></th>
                            <th><span class="w-fix-50">مشاهده</span></th>
                            <th><span class="w-fix-50">ویرایش</span></th>
                            <th><span class="w-fix-50">پیوست</span></th>
                            <th><span class="w-fix-180">بستانکار</span></th>
                            <th><span class="w-fix-180">بدهکار</span></th>
                            <th><span class="w-fix-150">نوع سند</span></th>
                            <th><span class="w-fix-350">شرح</span></th>
                            <th><span class="w-fix-150">وضعیت</span></th>
                            <th><span class="w-fix-200">زمان ثبت</span></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
        <div class="overflow-auto" id="@ViewData["Switch"]_MS" onscroll="ScrollSlave(this, '@ViewData["Switch"]_FT');">
            <table class="table grid-table">
                <thead class="header_Tablehiden">
                    <tr>
                        <th><span>#</span></th>
                        <th><span class="w-fix-100">تاریخ</span></th>
                        <th><span class="w-fix-90">شماره سند</span></th>
                        <th><span class="w-fix-50">مشاهده</span></th>
                        <th><span class="w-fix-50">ویرایش</span></th>
                        <th><span class="w-fix-50">پیوست</span></th>
                        <th><span class="w-fix-180">بستانکار</span></th>
                        <th><span class="w-fix-180">بدهکار</span></th>
                        <th><span class="w-fix-150">نوع سند</span></th>
                        <th><span class="w-fix-350">شرح</span></th>
                        <th><span class="w-fix-150">وضعیت</span></th>
                        <th><span class="w-fix-200">زمان ثبت</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow item in Model.ListData.Rows)
                    {
                        { RJ++; }
                        <tr onclick="RowSelect(this);">
                            <td class="text-danger">@RJ</td>
                            <td><span class="w-fixC-100">@item["EventDate"]</span></td>
                            <td><span class="w-fixC-90">@item["FinancialNum"]</span></td>
                            <td>
                                <button type="button" class="btn_Icon Icon_Mor icofont-2x icofont-search-2" title="مشاهده" onclick="ClickBtnSimpl('ListEventItemsBtn', '@item["FinancialEventId"]');"></button>
                            </td>
                            <td>
                                @if (@item["EventTypeCode"].ToString() == "5")
                                {
                                    <button type="button" class="btn_Icon Icon_Mor icofont-2x icofont-edit" title="ویرایش" onclick="ClickBtnSimpl('FormSabtVoucherBtn', '@item["FinancialEventId"]');"></button>
                                }
                            </td>
                            <td>
                                @if (@item["NameFile"].ToString() != "")
                                {
                                    <a class="btn_Icon Icon_Mor icofont-2x icofont-list" title="پیوست" target="_blank" href="/Uploads/VoucherAttach/@item["NameFile"]"></a>
                                }
                            </td>
                            <td><span class="w-fixC-200">@Html.Raw(@item["Bes"].ToMonySymbol())</span></td>
                            <td><span class="w-fixC-200">@Html.Raw(@item["Bed"].ToMonySymbol())</span></td>
                            <td><span class="w-fixC-150">@item["TypeTitle"]</span></td>
                            <td><span class="w-fixC-350">@item["Sharh"]</span></td>
                            <td><span class="w-fixC-150">@item["SitTitle"]</span></td>

                            <td><span class="w-fixC-200 text-start"><span>@item["EditorName"]</span><span class="text_line23">@item["TimeEdit"]</span></span></td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

        break;




    case "FormSabtVoucherItem":
        <section class="container p-1">
            <div class="secondArea">
                @if (ViewData["ItemID"].ToString() == "0")
                {
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                          data-ajax-confirm="آیا ردیف سند حسابداری ثبت گردد؟"
                          data-ajax-Btn="UpdateVoucherItemBtn"
                          data-ajax-begin="SpinnerShowForm('ردیف سند حسابداری', 'چند لحظه صبر کنید');"
                          data-ajax-url="?handler=UpdateVoucherItem"
                          data-ajax-complete="JsonClose_B"
                          data-ajax-success="ClickBtn('FormSabtVoucherBtn')">
                        <input type="hidden" name="ItemID" value="@ViewData["ItemID"]" />
                        <input type="hidden" name="EventID" value="@ViewData["EventID"]" />

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="py-1">
                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'حسابی که رویداد مالی را برای آن مینویسید را انتخاب کنید. حساب را از لیست منوکشویی زیر انتخاب کنید')"> حساب </label>
                                    <select class="control-input" name="AccountId" onchange="ShowTafzili(this,'BesBed')">
                                        <option value="0" data-Detail="4">انتخاب کنید</option>
                                        @foreach (DataRow item in Model.ListAccount.Rows)
                                        {
                                            <option value="@item["AccountId"]" data-Detail="@item["DetailCode"]">@item["AccountCode"] -> @item["AccountTitle"]</option>
                                        }
                                    </select>
                                    <div id="tafziliBesBedArea" class="dis-none">
                                        <div id="tafziliBesBed_1" class="dis-none">
                                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شخصی تفصیلی حساب مبدا را انتخاب کنید. برای اینکار ابتدا با فیلتر گذاری در زیر منوکشی اشخاص را پر کنید. سپس از منو کشویی شخص مورد نظر را انتخاب کنید .')"> شخص</label>
                                            <div class="d-flex">
                                                <input type="text" Id="filterTafziliBesBed_1" class="control-input text-center" value="" />
                                                <button type="button" class="btn_Icon Icon_Blue icofont-2x icofont-search" onclick="ClickBtnValueSimpl('ListFindTafziliBesBedBtn','filterTafziliBesBed_1','ListFindTafziliCodeBesBed','1')"></button>
                                            </div>
                                        </div>
                                        <div id="tafziliBesBed_2" class="dis-none">
                                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'واحدی تفصیلی حساب مبدا را انتخاب کنید. برای اینکار ابتدا با فیلتر گذاری در زیر منوکشی واحدها را پر کنید. سپس از منو کشویی واحد مورد نظر را انتخاب کنید .')"> واحد</label>
                                            <div class="d-flex">
                                                <input type="text" Id="filterTafziliBesBed_2" class="control-input text-center" value="" />
                                                <button type="button" class="btn_Icon Icon_Blue icofont-2x icofont-search" onclick="ClickBtnValueSimpl('ListFindTafziliBesBedBtn','filterTafziliBesBed_2','ListFindTafziliCodeBesBed','2')"></button>
                                            </div>
                                        </div>
                                        <div id="tafziliBesBed_3" class="dis-none">
                                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'قراداد تفصیلی حساب مبدا را انتخاب کنید. برای اینکار ابتدا با فیلتر گذاری در زیر منوکشی قراردادها را پر کنید. سپس از منو کشویی قرارداد مورد نظر را انتخاب کنید .')"> قرارداد</label>
                                            <div class="d-flex">
                                                <input type="text" Id="filterTafziliBesBed_3" class="control-input text-center" value="" />
                                                <button type="button" class="btn_Icon Icon_Blue icofont-2x icofont-search" onclick="ClickBtnValueSimpl('ListFindTafziliBesBedBtn','filterTafziliBesBed_3','ListFindTafziliCodeBesBed','3')"></button>
                                            </div>
                                        </div>
                                        <select class="control-input" id="ListFindTafziliBesBed" name="TafziliId">
                                            <option value="0">در محدوده بالا جستجو کنید</option>
                                        </select>
                                    </div>

                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="d-flex justify-content-around">
                                    <div class="w-fix-200">
                                        <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'اگر از حساب انتخاب شده برداشت مبلغ دارید یا میخواهید موجودی آن کاهش پیدا کند؛ مقدار بستانکاری را بنویسید')">بستانکار <i class="icofont icofont-riyal"></i></label>
                                        <input type="tel" class="control-input ltr text-center" id="AmountBes" name="AmountBes" onkeyup="AddComma(this)" onchange="SetValueSimpl('AmountBed','0')" value="@ViewData["Bes"].ToComma()"/>
                                    </div>
                                    <div class="w-fix-200">
                                        <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'اگر به حساب انتخاب شده واریز مبلغ دارید یا میخواهید موجودی آن افزایش پیدا کند؛ مقدار بدهکاری را بنویسید.')">بدهکار<i class="icofont icofont-riyal"></i></label>
                                        <input type="tel" class="control-input ltr text-center" id="AmountBed" name="AmountBed" onkeyup="AddComma(this)" onchange="SetValueSimpl('AmountBes','0')" value="@ViewData["Bed"].ToComma()" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شرح مناسبی در مورد این رویداد مالی بنویسید. این شرح کمک می کند که در آینده علت یا بابت این رویداد مالی و نحوه مدیریت آن را به یاد بیاورید')">شرح</label>
                            <textarea class="form-control text-center" rows="2" maxlength="300" name="Sharh"></textarea>
                        </div>
                        <hr />
                        <div class="text-end px-3">
                            <button type="submit" id="UpdateVoucherItemBtn" class="BTN btn_Pill btn_Blue2" title=" ثبت شود"><span> ثبت شود</span><i class=" icofont-00x icofont-check"></i></button>
                        </div>

                    </form>
                }
                else
                {
                    <form asp-antiforgery="true" method="post" data-ajax-method="post" data-ajax="true"
                          enctype="multipart/form-data"
                          data-ajax-confirm="آیا سند انتقال اصلاح گردد؟"
                          data-ajax-Btn="UpdateVoucherItemBtn"
                          data-ajax-begin="SpinnerShowForm('سند انتقال بین دو حساب', 'چند لحظه صبر کنید');"
                          data-ajax-url="?handler=UpdateVoucherItem"
                          data-ajax-complete="JsonClose_A">
                        <input type="hidden" name="ID" value="@ViewData["ID"]" />


                        <div class="row">
                            <div class="col-sm-6">

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'این مبلغ را در چه تاریخی منتقل کردید؟ یک سند با همین تاریخ ایجاد خواهد شد.')"> در تاریخ  </label>
                                        <div class="control-Date w-fix-150">
                                            <input id="DateAction" name="DateAction" maxlength="10" readonly class="usage control-input-plaintext" value="@Model.RowData["DateAction"]" />
                                        </div>
