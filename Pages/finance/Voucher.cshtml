                  data-ajax-url="?handler=FormSabtPardakht"
                  data-ajax-update="#MsgFormMATN_A">
                <input type="submit" hidden id="FormSabtPardakhtBtn" name="ID" />
                <div class="px-2 text-end">
                    <button type="button" class="BTN btn_Pill btn_Blue2" onclick="ClickBtnSimpl('FormSabtPardakhtBtn','0');"><span>ثبت پرداخت جدید</span><i class="icofont-00x icofont-plus"></i></button>
                </div>
            </form>


            <div class="filterArea">

                <form asp-antiforgery="true" method="get" data-ajax-method="get" data-ajax="true"
