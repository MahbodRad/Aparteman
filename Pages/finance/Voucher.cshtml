                        <div id="AreaBtnTransfer">
                            <button type="button" class="BTN btn_Pill btn_Firuze m-2 w-min-75" onclick="Btn_Select(this, 'AreaBtnTransfer'); FastReportAjax('TD', 'BtnRepTransfer', 'TRS', 'TRS_LimitDate');">امروز</button>
                            <button type="button" class="BTN btn_Pill btn_Firuze m-2 w-min-75" onclick="Btn_Select(this, 'AreaBtnTransfer'); FastReportAjax('1W', 'BtnRepTransfer', 'TRS', 'TRS_LimitDate');">هفته</button>
                            <button type="button" class="BTN btn_Pill btn_Firuze m-2 w-min-75" onclick="Btn_Select(this, 'AreaBtnTransfer'); FastReportAjax('2W', 'BtnRepTransfer', 'TRS', 'TRS_LimitDate');">دوهفته</button>
                            <button type="button" class="BTN btn_Pill btn_Firuze m-2 w-min-75" onclick="Btn_Select(this, 'AreaBtnTransfer'); FastReportAjax('1M', 'BtnRepTransfer', 'TRS', 'TRS_LimitDate');">یک ماه</button>
                            <button type="button" class="BTN btn_Pill btn_Firuze m-2 w-min-75" onclick="Btn_Select(this, 'AreaBtnTransfer'); FastReportAjax('3M', 'BtnRepTransfer', 'TRS', 'TRS_LimitDate');">سه ماه</button>
                            <button type="button" class="BTN btn_Pill btn_Firuze m-2 w-min-75" onclick="Btn_Select(this, 'AreaBtnTransfer'); FastReportAjax('TM', 'BtnRepTransfer', 'TRS', 'TRS_LimitDate');">ماه جاری</button>
                            <button type="button" class="BTN btn_Top btn_Light m-2 w-min-75" onclick="Btn_Select(this, 'AreaBtnTransfer'); AreaToggel('ReportSazTransfer');">گزارش ساز <span class="text-primary icofont-00x icofont-cubes"></span></button>
                        </div>
                        <div id="ReportSazTransfer" class="alert alert-info rounded p-3 dis-none border shadow">
                            <div class="row">
                                <div class="col-12 col-sm-3">
                                    <div class="w-fix-180 mx-1">
                                        <span class="control-label">محدوده تاریخ</span>
                                        <select class="control-input" id="TRS_LimitDate" onchange="LimitDateAjax(this,'TRS');">
                                            <option value="0" selected>انتخاب شود</option>
                                            <option value="TD">امروز</option>
                                            <option value="1W">یک هفته</option>
                                            <option value="2W">دو هفته</option>
                                            <option value="1M">یک ماه</option>
                                            <option value="TM">ماه جاری</option>
                                            <option value="LM">ماه قبل</option>
                                            <option value="3M">سه ماه</option>
                                            <option value="6M">شش ماه</option>
                                            <option value="1Y">یکسال</option>
                                            <option value="TY">امسال</option>
                                            <option value="LY">پارسال</option>
                                        </select>

                                        <div id="waitLimitDateTRS"></div>

                                        <span class="control-label">از تاریخ</span>
                                        <div class="control-Date">
                                            <input placeholder="از تاریخ" id="FromDateTRS" name="FromDate" maxlength="10" readonly class="usage control-input-plaintext" value="@ViewData["Today"]" />
                                        </div>
                                        <span class="control-label">تا تاریخ</span>
                                        <div class="control-Date">
                                            <input placeholder="از تاریخ" id="ToDateTRS" name="ToDate" maxlength="10" readonly class="usage control-input-plaintext" value="@ViewData["Today"]" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-sm-9">
                                    <div class="row">
                                        <div class="col-12 col-sm-4">
                                            <span class="control-label">حساب </span>
                                            <select class="control-input" name="AccountId" onchange="ShowTafziliRep(this,'TRS')">
                                                <option value="0" data-Detail="4">همه حساب ها</option>
                                                @foreach (DataRow item in Model.ListAccount.Rows)
                                                {
                                                    @if (@item["AccountTypeCode"].ToString() == "1")
                                                    {
                                                        <option value="@item["AccountId"]" data-Detail="@item["DetailCode"]">@item["AccountCode"] -> @item["AccountTitle"]</option>
                                                    }
                                                }
                                            </select>
                                            <div id="tafziliRepTRSArea" class="dis-none">
                                                <div id="tafziliRepTRS_1" class="dis-none">
                                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'شخصی که از او این مبلغ را دریافت کرده اید انتخاب کنید. برای اینکار ابتدا با فیلتر گذاری در زیر منوکشی اشخاص را پر کنید. سپس از منو کشویی شخص مورد نظر را انتخاب کنید .')">از شخص</label>
                                                    <div class="d-flex">
                                                        <input type="text" Id="filtertafziliRepTRS_1" class="control-input text-center" value="" />
                                                        <button type="button" class="btn_Icon Icon_Blue icofont-2x icofont-search" onclick="ClickBtnValueSimpl('ListFindtafziliRepTRSBtn','filtertafziliRepTRS_1','ListFindTafziliCodeTRS','1')"></button>
                                                    </div>
                                                </div>
                                                <div id="tafziliRepTRS_2" class="dis-none">
                                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'واحدی که از او این مبلغ را دریافت کرده اید انتخاب کنید. برای اینکار ابتدا با فیلتر گذاری در زیر منوکشی واحدها را پر کنید. سپس از منو کشویی واحد مورد نظر را انتخاب کنید .')">از واحد</label>
                                                    <div class="d-flex">
                                                        <input type="text" Id="filtertafziliRepTRS_2" class="control-input text-center" value="" />
                                                        <button type="button" class="btn_Icon Icon_Blue icofont-2x icofont-search" onclick="ClickBtnValueSimpl('ListFindtafziliRepTRSBtn','filtertafziliRepTRS_2','ListFindTafziliCodeTRS','2')"></button>
                                                    </div>
                                                </div>
                                                <div id="tafziliRepTRS_3" class="dis-none">
                                                    <label class="control-label cursor-pointer" onclick="ShowFastHelp(this,'قرادادی که طبق آن این مبلغ را دریافت کرده اید انتخاب کنید. برای اینکار ابتدا با فیلتر گذاری در زیر منوکشی قراردادها را پر کنید. سپس از منو کشویی قرارداد مورد نظر را انتخاب کنید .')">از قرارداد</label>
                                                    <div class="d-flex">
                                                        <input type="text" Id="filtertafziliRepTRS_3" class="control-input text-center" value="" />
                                                        <button type="button" class="btn_Icon Icon_Blue icofont-2x icofont-search" onclick="ClickBtnValueSimpl('ListFindtafziliRepTRSBtn','filtertafziliRepTRS_3','ListFindTafziliCodeTRS','3')"></button>
                                                    </div>
                                                </div>
                                                <select class="control-input" id="ListFindtafziliRepTRS" name="TafziliBes">
                                                    <option value="0">در محدوده بالا جستجو کنید</option>
                                                </select>

                                            </div>

                                        </div>
                                        <div class="col-12 col-sm-4">
                                            <span class="control-label">مرتب سازی</span>
                                            <select class="control-input" name="Sort">
                                                <option value="A">تاریخ</option>
                                                <option value="B">تاریخ کاهشی</option>
                                            </select>
                                        </div>
                                        <div class="col-12 col-sm-4">
                                            <span class="control-label">شرح</span>
                                            <input class="control-input" name="Sharh" value="" />
                                        </div>
                                    </div>

                                    <div class="pt-4 text-end">
                                        <button type="submit" id="BtnRepTransfer" class="BTN btn_Pill btn_Blue2" onclick="AreaUp('ReportSazTransfer')"><span>جستجوی سندهای پرداخت</span><i class="icofont-2x icofont-search-2"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>


                </form>

            </div>

        </div>

        <div class="container-fluid">
            <div class="mt-3" id="RepListTransfer">
                <div class="alert alert-info w-max-400 mx-auto cursor-pointer" onclick="FastReportAjax('1M', 'BtnRepTransfer', 'TRS', 'TRS_LimitDate');">
                    <i class="icofont-search-2" style="font-size:40px;"></i>
                    <h6 class="mt-3">هنوز جستجویی انجام نشده</h6>
                    <p class="text-muted">برای مشاهده دریافت های یک ماه اخیر کلیک کنید، و یا از فیلترهای بالا استفاده کنید</p>
                </div>
            </div>
        </div>

    </div>

</div>

